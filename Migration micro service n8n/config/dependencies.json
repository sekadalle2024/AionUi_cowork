{
  "description": "Dépendances NPM requises pour le microservice n8n",
  "backend": {
    "dependencies": {
      "express": "^5.1.0",
      "cors": "^2.8.5"
    },
    "devDependencies": {
      "@types/express": "^4.17.x",
      "@types/cors": "^2.8.x",
      "ts-node": "^10.9.2",
      "typescript": "^5.8.3"
    },
    "installation": {
      "command": "npm install express cors",
      "devCommand": "npm install @types/express @types/cors ts-node typescript --save-dev"
    }
  },
  "frontend": {
    "dependencies": {
      "react": "^19.1.0",
      "react-dom": "^19.1.0",
      "@arco-design/web-react": "^2.66.1",
      "react-markdown": "^10.1.0",
      "react-i18next": "^14.0.5"
    },
    "devDependencies": {
      "@types/react": "^19.x.x",
      "@types/react-dom": "^19.x.x"
    },
    "installation": {
      "command": "npm install react react-dom @arco-design/web-react react-markdown react-i18next",
      "devCommand": "npm install @types/react @types/react-dom --save-dev"
    }
  },
  "requirements": {
    "nodejs": ">=18.0.0",
    "reason": "Utilise fetch natif disponible en Node.js 18+",
    "verification": "node --version"
  },
  "optional": {
    "winston": {
      "version": "^3.x.x",
      "purpose": "Logging avancé pour production",
      "installation": "npm install winston"
    },
    "dotenv": {
      "version": "^17.x.x",
      "purpose": "Gestion des variables d'environnement",
      "installation": "npm install dotenv"
    }
  },
  "notes": [
    "Toutes les dépendances frontend sont probablement déjà installées dans un projet React existant",
    "Les dépendances backend sont légères et rapides à installer",
    "Node.js 18+ est OBLIGATOIRE pour le fetch natif",
    "TypeScript et ts-node sont nécessaires pour exécuter le serveur backend"
  ]
}
